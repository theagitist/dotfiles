[include]
    path = ~/.gitconfig.local

[core]
    editor = vim
    autocrlf = input
    pager = delta

[init]
    defaultBranch = main

[pull]
    rebase = true

[rebase]
    autoStash = true

[push]
    default = current
    autoSetupRemote = true

[fetch]
    prune = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    syntax-theme = Dracula

[column]
    ui = auto

[diff]
    colorMoved = zebra
    algorithm = histogram

[merge]
    conflictstyle = diff3

[rerere]
    enabled = true

[alias]
    st = status -sb
    lg = log --oneline --graph --decorate --all
    co = checkout
    br = branch
    cm = commit
    last = log -1 HEAD --stat
    unstage = reset HEAD --
    amend = commit --amend --no-edit
    sw = switch
    rs = restore
    sc = switch -c
