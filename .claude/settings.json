{
  "env": {
    "PATH": "/home/theagitist/.bun/bin:/home/theagitist/.local/bin:/home/theagitist/.nvm/versions/node/v25.8.1/bin:/home/theagitist/.cargo/bin:/snap/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  },
  "permissions": {
    "allow": [
      "mcp__pencil"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "unset -f node npm nvm npx 2>/dev/null; true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "telegram@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  }
}
